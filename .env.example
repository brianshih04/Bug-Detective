# Bug-Detective 環境設定
# 複製此檔案為 .env 並填入實際值：cp .env.example .env

# --- 原始碼目錄 ---
SOURCE_DIR=/home/avuser/infernoStart01

# --- Qdrant 向量資料庫 ---
QDRANT_URL=http://localhost:6333
COLLECTION_NAME=infernoStart01

# --- Ollama 本地 LLM ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.6:35b-a3b-200k
EMBEDDING_MODEL=qwen3-embedding:8b
EMBEDDING_DIM=4096

# --- z.ai GLM-5 雲端 LLM ---
GLM5_BASE_URL=https://api.z.ai/api/coding/paas/v4
GLM5_API_KEY=
GLM5_MODEL=glm-5-turbo

# --- 伺服器 ---
PORT=17580
